{
  "name": "openfy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Open source music streaming app powered by Piped",
  "author": "Openfy",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "install:all": "npm install && cd client && npm install",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder --win",
    "electron:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@xhayper/discord-rpc": "^1.3.4",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "express": "^4.21.0",
    "ws": "^8.20.0",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "jimp": "^1.6.1"
  },
  "build": {
    "appId": "com.openfy.app",
    "productName": "Openfy",
    "npmRebuild": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/dist/**/*",
      "assets/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/icon.png",
        "to": "icon.png"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Openfy"
    },
    "portable": {
      "artifactName": "Openfy-Portable-${version}.exe"
    },
    "protocols": [
      {
        "name": "Openfy",
        "schemes": [
          "openfy"
        ]
      }
    ]
  }
}
